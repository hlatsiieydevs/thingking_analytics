# Database Configuration
# In docker-compose, postgres host is 'postgres'
DATABASE_URL="postgresql://postgres:postgres_secure_pass@postgres:5432/thingking_analytics?schema=public"

# RabbitMQ Configuration
# In docker-compose, rabbitmq host is 'rabbitmq'
RABBITMQ_URL="amqp://guest:guest@rabbitmq:5672"

# Ingest Server Settings
INGEST_PORT=4000
BACKLOG_UPLOAD_DIR="./uploads"

# UI Server Settings
UI_PORT=5000

# Telemetry Data Lake Configuration
DATA_LAKE_LOCAL_PATH="./data_lake_raw"

# Security Configurations
JWT_SECRET="generate_a_secure_jwt_secret_token_here"

# Networking & Tunneling (Ngrok & Tailscale)
NGROK_AUTHTOKEN="your_ngrok_authtoken_here"
TAILSCALE_AUTHKEY="tskey-auth-xxxxxx-your_tailscale_key"
